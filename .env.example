# ── OmniFlow Environment Variables ──────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

APP_NAME="OmniFlow API"
APP_VERSION="0.1.0"
DEBUG=true
ENVIRONMENT=development
# Use "staging" or "production" in deployed environments.
# In non-development mode, SECRET_KEY and ENCRYPTION_KEY MUST be real secrets.

DATABASE_URL=postgresql+asyncpg://omniflow:omniflow@localhost:5432/omniflow
REDIS_URL=redis://localhost:6379/0

# ── Security ────────────────────────────────
# Generate with: openssl rand -hex 64
SECRET_KEY=<REPLACE-run-openssl-rand-hex-64>
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=<REPLACE-run-openssl-rand-hex-32>

ALLOWED_ORIGINS=["http://localhost:3000"]
NEXT_PUBLIC_API_URL=http://localhost:8000
LOG_LEVEL=INFO

# ── Rate Limiting ───────────────────────────
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_AUTH_PER_MINUTE=30

# ── AI / LLM — Multi-Provider (Nova) ────────────────────
# Format JSON : [{"name":"...","base_url":"...","api_key":"...","model":"..."}]
AI_PROVIDERS=[]

# Legacy OpenAI (optional, used as last resort if AI_PROVIDERS fails)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_DAILY_LIMIT=20

# ── OmniFlow Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values.

# App
APP_NAME="OmniFlow API"
APP_VERSION="0.1.0"
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://omniflow:omniflow@localhost:5432/omniflow

# Redis
REDIS_URL=redis://localhost:6379/0

# Security — CHANGE IN PRODUCTION
SECRET_KEY=dev-secret-key-change-me-in-production-use-openssl-rand-hex-64

# CORS
ALLOWED_ORIGINS=["http://localhost:3000"]

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

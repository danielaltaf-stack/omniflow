# ══════════════════════════════════════════════════════════════
# OmniFlow — Production Environment Variables
# ══════════════════════════════════════════════════════════════
# Target: Railway + Neon + Upstash + Cloudflare + Sentry
#
# Copy to Railway dashboard → Variables tab.
# Generate secrets with:
#   SECRET_KEY:     openssl rand -hex 64
#   ENCRYPTION_KEY: openssl rand -hex 32
# ══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
APP_NAME="OmniFlow API"
APP_VERSION="0.5.0"
DEBUG=false
ENVIRONMENT=production
LOG_LEVEL=WARNING
LAUNCH_MODE=beta
# waitlist → invite-only, beta → open beta, public → GA

# ── CORS / Frontend ─────────────────────────────────────────
ALLOWED_ORIGINS=["https://app.omniflow.app"]
NEXT_PUBLIC_API_URL=https://api.omniflow.app

# ── Database (Neon Serverless PostgreSQL) ────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require
DATABASE_URL=postgresql+asyncpg://neondb_owner:CHANGE_ME@ep-xxx-yyy-zzz.eu-central-1.aws.neon.tech/neondb?sslmode=require
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=300
DB_STATEMENT_TIMEOUT_MS=30000
# Neon auto-scales. Pool sizes lower than dev because Neon has 100 concurrent limit.
# DB_POOL_RECYCLE=300 (5 min) — Neon may drop idle connections; keep pool fresh.

# ── Redis (Upstash Serverless Redis) ────────────────────────
# Format: rediss://<user>:<password>@<host>.upstash.io:6379
# Note: rediss:// (double s) = TLS mandatory. Upstash enforces this.
REDIS_URL=rediss://default:CHANGE_ME@eu1-xxx-yyy.upstash.io:6379
REDIS_MAX_CONNECTIONS=10
# Upstash Free: 10k commands/day. Pro: unlimited.
# Connections are multiplexed; 10 is enough even at scale.

# ── Workers ─────────────────────────────────────────────────
WEB_CONCURRENCY=2
# Railway Hobby: 8 GB RAM, 8 vCPU.
# 2 workers × 1 thread = low memory footprint. Scale replicas instead.

# ── Security — CHANGE THESE (mandatory, boot guard enforced) ─
SECRET_KEY=GENERATE_WITH_openssl_rand_hex_64
ENCRYPTION_KEY=GENERATE_WITH_openssl_rand_hex_32

# ── JWT ─────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# ── Rate Limiting (per user) ────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW_SECONDS=900
BCRYPT_ROUNDS=13

# ── Scheduler ───────────────────────────────────────────────
SYNC_INTERVAL_HOURS=6
SYNC_MAX_CONCURRENT=3

# ── Sentry (Error Tracking & APM) ───────────────────────────
# Get DSN from: https://sentry.io → Project → Settings → Client Keys
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=production

# ── External APIs (optional) ────────────────────────────────
ETHERSCAN_API_KEY=
COINGECKO_API_KEY=

# ── AI / LLM ────────────────────────────────────────────────
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
AI_DAILY_LIMIT=20

# ── Push Notifications (VAPID) ──────────────────────────────
# Generate: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=GENERATE_WITH_WEBPUSH
VAPID_PUBLIC_KEY=GENERATE_WITH_WEBPUSH
VAPID_SUBJECT=mailto:contact@omniflow.app

# ── Cache TTLs (seconds) — Production-optimized ─────────────
CACHE_TTL_DASHBOARD=120
CACHE_TTL_NETWORTH=300
CACHE_TTL_NETWORTH_HISTORY=600
CACHE_TTL_CASHFLOW=600
CACHE_TTL_OMNISCORE=86400
CACHE_TTL_BUDGET=300
CACHE_TTL_RETIREMENT=600
CACHE_TTL_HERITAGE=600
CACHE_TTL_FEE_NEGOTIATOR=600
CACHE_TTL_FISCAL_RADAR=600
CACHE_TTL_WEALTH_AUTOPILOT=300
CACHE_TTL_DIGITAL_VAULT=300

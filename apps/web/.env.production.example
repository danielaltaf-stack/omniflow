# ══════════════════════════════════════════════════════════════
# OmniFlow Frontend — Production Environment Variables
# ══════════════════════════════════════════════════════════════
# Set these in Vercel Dashboard → Project → Environment Variables
# Or in Railway if using Dockerfile.prod deployment.
# ══════════════════════════════════════════════════════════════

# ── API Backend ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.omniflow.app

# ── App Identity ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://omniflow.app
NEXT_PUBLIC_APP_VERSION=0.5.0

# ── Sentry (Error Tracking — Frontend) ─────────────────────
# Get DSN from: https://sentry.io → Project (frontend) → Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# ── Analytics (Plausible — RGPD compliant) ──────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=omniflow.app

# ── Build (auto-set by Vercel, manual for Docker) ──────────
# NEXT_PUBLIC_BUILD_ID is auto-set by Vercel ($VERCEL_GIT_COMMIT_SHA)
# For Docker: set to git commit hash during build
NEXT_PUBLIC_BUILD_ID=

# ── Bundle Analysis (debug only) ───────────────────────────
ANALYZE=false
